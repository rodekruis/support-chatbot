PORT=8000
# Deployment environment. Non-prod values (e.g. "dev") suffix the vector store
# index names (support-chatbot-index-{manual_id}-{ENVIRONMENT}) so a dev deploy
# never overwrites the prod index. "prod" keeps the bare index name.
ENVIRONMENT=prod
AUTH_API_KEY=read-key
AUTH_API_KEY_WRITE=write-key
VECTOR_STORE_ADDRESS=https://my-vector-search.search.windows.net
VECTOR_STORE_PASSWORD=password
AZURE_OPENAI_ENDPOINT=https://my-openai.openai.azure.com
AZURE_OPENAI_API_KEY=openapi-key
AZURE_OPENAI_API_VERSION=openapi-version
MODEL_EMBEDDINGS=model-name
MODEL_CHAT=model-name
# Optional, evaluation-only: separate (stronger) model used as the
# LLM-as-judge in offline RAG quality tests. Leave unset to skip those tests.
MODEL_JUDGE=model-name
# Optional, observability-only: self-hosted Langfuse for LLM tracing.
# Leave the keys unset to disable tracing entirely.
LANGFUSE_BASE_URL=https://langfuse.example.org
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
